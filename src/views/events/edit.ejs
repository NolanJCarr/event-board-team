<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold">Edit Event</h1>
    <!-- Status Badge -->
    <span class="px-3 py-1 rounded-full text-sm font-medium
      <%= event.status === 'draft' ? 'bg-gray-200 text-gray-700' : '' %>
      <%= event.status === 'published' ? 'bg-green-200 text-green-800' : '' %>
      <%= event.status === 'cancelled' ? 'bg-red-200 text-red-800' : '' %>
      <%= event.status === 'past' ? 'bg-gray-300 text-gray-600' : '' %>">
      <%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %>
    </span>
  </div>

  <!-- Error display if pageError exists -->
  <% if (pageError) { %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-md p-4" role="alert">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-red-800"><%= pageError %></p>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Event Editing Form -->
  <div x-data="{
    hasUnsavedChanges: false,
    isSubmitting: false,
    titleCount: '<%= event.title.length %>',
    descriptionCount: '<%= event.description.length %>',
    originalValues: {
      title: `<%= event.title.replace(/`/g, '\\`').replace(/\$/g, '\\$').replace(/\\/g, '\\\\') %>`,
      description: `<%= event.description.replace(/`/g, '\\`').replace(/\$/g, '\\$').replace(/\\/g, '\\\\') %>`,
      location: `<%= event.location.replace(/`/g, '\\`').replace(/\$/g, '\\$').replace(/\\/g, '\\\\') %>`,
      category: '<%= event.category %>',
      startTime: '<%= startTimeFormatted %>',
      endTime: '<%= endTimeFormatted %>',
      capacity: '<%= event.capacity !== undefined ? event.capacity : "" %>'
    },
    checkForChanges() {
      const form = $refs.editForm;
      if (!form) return;
      const currentValues = {
        title: form.title.value,
        description: form.description.value,
        location: form.location.value,
        category: form.category.value,
        startTime: form.startTime.value,
        endTime: form.endTime.value,
        capacity: form.capacity.value
      };
      this.hasUnsavedChanges = JSON.stringify(currentValues) !== JSON.stringify(this.originalValues);
    },
    confirmCancel(event) {
      if (this.hasUnsavedChanges) {
        if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
          event.preventDefault();
        } else {
          // User confirmed - disable warning for this navigation
          this.hasUnsavedChanges = false;
        }
      }
    }
  }"
  x-init="window.addEventListener('beforeunload', (e) => { if ($data.hasUnsavedChanges && !$data.isSubmitting) { e.preventDefault(); e.returnValue = ''; } })"
  >
  <form x-ref="editForm" method="POST" action="/events/<%= event.id %>" class="bg-white rounded-lg shadow p-6" @input="checkForChanges()" @change="checkForChanges()" @submit="isSubmitting = true">

    <!-- Title -->
    <div class="mb-4">
      <label for="title" class="block text-sm font-medium text-gray-700 mb-1">
        Event Title <span class="text-red-500" aria-label="required">*</span>
      </label>
      <input
        type="text"
        id="title"
        name="title"
        required
        maxlength="200"
        value="<%= event.title %>"
        placeholder="e.g., Spring Hackathon 2026"
        class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        aria-describedby="title-help"
        x-on:input="titleCount = $event.target.value.length"
      />
      <p id="title-help" class="text-xs mt-1" :class="titleCount > 180 ? 'text-orange-600 font-medium' : titleCount > 195 ? 'text-red-600 font-semibold' : 'text-gray-500'">
        <span x-text="titleCount"></span> / 200 characters
      </p>
    </div>

    <!-- Description -->
    <div class="mb-4">
      <label for="description" class="block text-sm font-medium text-gray-700 mb-1">
        Description <span class="text-red-500" aria-label="required">*</span>
      </label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="2000"
        rows="5"
        placeholder="Describe your event..."
        class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        aria-describedby="description-help"
        x-on:input="descriptionCount = $event.target.value.length"
      ><%= event.description %></textarea>
      <p id="description-help" class="text-xs mt-1" :class="descriptionCount > 1800 ? 'text-orange-600 font-medium' : descriptionCount > 1950 ? 'text-red-600 font-semibold' : 'text-gray-500'">
        <span x-text="descriptionCount"></span> / 2000 characters
      </p>
    </div>

    <!-- Location -->
    <div class="mb-4">
      <label for="location" class="block text-sm font-medium text-gray-700 mb-1">
        Location <span class="text-red-500" aria-label="required">*</span>
      </label>
      <input
        type="text"
        id="location"
        name="location"
        required
        maxlength="200"
        value="<%= event.location %>"
        placeholder="e.g., Campus Center Room 101"
        class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        aria-describedby="location-help"
      />
      <p id="location-help" class="text-xs text-gray-500 mt-1">Maximum 200 characters</p>
    </div>

    <!-- Category -->
    <div class="mb-4">
      <label for="category" class="block text-sm font-medium text-gray-700 mb-1">
        Category <span class="text-red-500" aria-label="required">*</span>
      </label>
      <select
        id="category"
        name="category"
        required
        class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        aria-describedby="category-help"
      >
        <option value="">Select a category...</option>
        <option value="social" <%= event.category === 'social' ? 'selected' : '' %>>Social</option>
        <option value="educational" <%= event.category === 'educational' ? 'selected' : '' %>>Educational</option>
        <option value="volunteer" <%= event.category === 'volunteer' ? 'selected' : '' %>>Volunteer</option>
        <option value="sports" <%= event.category === 'sports' ? 'selected' : '' %>>Sports</option>
        <option value="arts" <%= event.category === 'arts' ? 'selected' : '' %>>Arts</option>
        <option value="tech" <%= event.category === 'tech' ? 'selected' : '' %>>Tech</option>
        <option value="other" <%= event.category === 'other' ? 'selected' : '' %>>Other</option>
      </select>
      <p id="category-help" class="text-xs text-gray-500 mt-1">Choose the category that best describes this event</p>
    </div>

    <!-- Start Time and End Time (side by side) -->
    <div class="flex flex-col sm:flex-row gap-4 mb-4">
      <div class="flex-1">
        <label for="startTime" class="block text-sm font-medium text-gray-700 mb-1">
          Start Time <span class="text-red-500" aria-label="required">*</span>
        </label>
        <input
          type="datetime-local"
          id="startTime"
          name="startTime"
          required
          value="<%= startTimeFormatted %>"
          class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          aria-describedby="startTime-help"
        />
        <p id="startTime-help" class="text-xs text-gray-500 mt-1">When the event begins</p>
      </div>

      <div class="flex-1">
        <label for="endTime" class="block text-sm font-medium text-gray-700 mb-1">
          End Time <span class="text-red-500" aria-label="required">*</span>
        </label>
        <input
          type="datetime-local"
          id="endTime"
          name="endTime"
          required
          value="<%= endTimeFormatted %>"
          class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          aria-describedby="endTime-help"
        />
        <p id="endTime-help" class="text-xs text-gray-500 mt-1">When the event ends</p>
      </div>
    </div>

    <!-- Capacity (optional) -->
    <div class="mb-6">
      <label for="capacity" class="block text-sm font-medium text-gray-700 mb-1">
        Capacity (optional)
      </label>
      <input
        type="number"
        id="capacity"
        name="capacity"
        min="1"
        value="<%= event.capacity !== undefined ? event.capacity : '' %>"
        placeholder="Leave blank for unlimited"
        class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        aria-describedby="capacity-help"
      />
      <p id="capacity-help" class="text-xs text-gray-500 mt-1">Maximum number of attendees (leave blank for unlimited capacity)</p>
    </div>

    <!-- Form Actions -->
    <div class="flex gap-3">
      <button
        type="submit"
        class="flex-1 bg-blue-600 text-white font-medium px-4 py-2 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors"
        aria-label="Save changes to event"
      >
        Save Changes
      </button>
      <a
        href="/events/<%= event.id %>"
        class="flex-1 text-center bg-gray-200 text-gray-700 font-medium px-4 py-2 rounded-md hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 transition-colors"
        aria-label="Cancel editing and return to event details"
        @click="confirmCancel($event)"
      >
        Cancel
      </a>
    </div>

    <!-- Help text -->
    <div class="mt-4 space-y-2">
      <p class="text-xs text-gray-500">
        <span class="text-red-500" aria-hidden="true">*</span>
        <span class="sr-only">Asterisk indicates</span>
        Required fields
      </p>
      <% if (event.status === 'published') { %>
        <p class="text-xs text-blue-600">
          <strong>Note:</strong> This event is currently published. Changes will be visible to members immediately.
        </p>
      <% } %>
      <% if (event.status === 'draft') { %>
        <p class="text-xs text-gray-600">
          <strong>Note:</strong> This event is in draft status. It will not be visible to members until published.
        </p>
      <% } %>
    </div>
  </form>
  </div>
</div>
