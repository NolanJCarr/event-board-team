<div id="event-create-form" class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-4 bg-green-50 border border-green-200 rounded-md p-4">
    <h2 class="text-xl font-bold text-green-800 mb-2">Event Created Successfully!</h2>
    <p class="text-sm text-green-700">Your event "<%= event.title %>" has been created as a draft.</p>
  </div>

  <div class="space-y-2 text-sm text-gray-700 mb-4">
    <p><strong>Title:</strong> <%= event.title %></p>
    <p><strong>Location:</strong> <%= event.location %></p>
    <p><strong>Category:</strong> <%= event.category %></p>
    <p><strong>Start:</strong> <%= event.startTime.toLocaleString() %></p>
    <p><strong>End:</strong> <%= event.endTime.toLocaleString() %></p>
    <% if (event.capacity) { %>
      <p><strong>Capacity:</strong> <%= event.capacity %> attendees</p>
    <% } %>
  </div>

  <div class="flex gap-3">
    <a
      href="/events/<%= event.id %>"
      class="flex-1 text-center bg-blue-600 text-white font-medium px-4 py-2 rounded-md hover:bg-blue-700 transition-colors"
    >
      View Event
    </a>
    <a
      href="/events/new"
      class="flex-1 text-center bg-gray-200 text-gray-700 font-medium px-4 py-2 rounded-md hover:bg-gray-300 transition-colors"
    >
      Create Another
    </a>
  </div>
</div>
