<div class="bg-white border border-slate-200 rounded-2xl shadow-lg p-6 space-y-6">

  <h2 class="text-xl font-bold text-slate-900">Attendees</h2>

  <!-- Going -->
  <div>
    <h3 class="text-green-700 font-bold mb-2">Going:</h3>
    <ul class="space-y-1">
      <% attendees.attending.forEach(a => { %>
        <li class="flex justify-between text-sm text-slate-700 bg-green-50 px-3 py-2 rounded-md">
          <span><%= a.displayName %></span>
          <span class="text-slate-500"><%= a.rsvpedAt.toLocaleDateString() %></span>
        </li>
      <% }) %>
    </ul>
  </div>

  <!--Waitlisted-->
  <div>
    <h3 class = "text-yellow-700 font-bold mb-2">Waitlisted:</h3>
    <ul class = "space-y-1">
      <% attendees.waitlisted.forEach(a => { %>
      <li class = "flex justify between text-sm text-slate-700 bg-yellow-50 px-3 py-2 rounded-md">
      </li>
    <%}) %>
    </ul>
  </div>

  <!--Cancelled-->
  <div>
    <h3 class = "text-red-700 font-bold mb-2">Cancelled:</h3>
    <ul class = "space-y-1">
      <% attendees.cancelled.forEach(a => { %>
      <li class = "flex justify between text-sm text-slate-700 bg-red-50 px-3 py-2 rounded-md">
      </li>
    <%}) %>
    </ul>
  </div>
  