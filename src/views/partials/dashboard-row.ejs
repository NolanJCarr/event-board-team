<% const statusColors = {
  draft: 'bg-yellow-100 text-yellow-800',
  published: 'bg-green-100 text-green-800',
  cancelled: 'bg-red-100 text-red-800',
  past: 'bg-gray-100 text-gray-600',
};
const badge = statusColors[event.status] || 'bg-slate-100 text-slate-600';
%>
<li id="event-row-<%= event.id %>" class="p-4 bg-white border border-slate-200 rounded-xl shadow-sm flex items-center justify-between gap-4">
  <div class="min-w-0">
    <a href="/events/<%= event.id %>" class="text-slate-900 font-semibold hover:text-blue-700 no-underline truncate block"><%= event.title %></a>
    <span class="text-slate-500 text-xs"><%= event.startTime.toLocaleDateString() %></span>
  </div>
  <div class="flex items-center gap-3 shrink-0">
    <span class="text-slate-600 text-sm"><%= event.attendeeCount %> going</span>
    <span class="inline-block px-2.5 py-1 text-xs font-medium rounded-full <%= badge %>"><%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %></span>
    <% if (event.status === 'draft') { %>
      <button
        type="button"
        class="px-2.5 py-1 text-xs font-medium rounded-md bg-green-600 text-white hover:bg-green-700"
        hx-post="/events/<%= event.id %>/publish"
        hx-target="#event-row-<%= event.id %>"
        hx-swap="outerHTML"
      >Publish</button>
    <% } %>
    <% if (event.status === 'published') { %>
      <button
        type="button"
        class="px-2.5 py-1 text-xs font-medium rounded-md bg-red-600 text-white hover:bg-red-700"
        hx-post="/events/<%= event.id %>/cancel"
        hx-target="#event-row-<%= event.id %>"
        hx-swap="outerHTML"
        hx-confirm="Cancel this event? This cannot be undone."
      >Cancel</button>
    <% } %>
  </div>
</li>
