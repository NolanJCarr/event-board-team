<% function statusBadge(status) {
  const map = {
    draft: 'bg-yellow-100 text-yellow-800',
    published: 'bg-green-100 text-green-800',
    cancelled: 'bg-red-100 text-red-800',
    past: 'bg-gray-100 text-gray-600',
  };
  return map[status] || 'bg-slate-100 text-slate-600';
} %>

<% function renderSection(title, events) { %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-slate-700 mb-3"><%= title %> <span class="text-slate-400 font-normal text-sm">(<%= events.length %>)</span></h2>
    <% if (events.length === 0) { %>
      <p class="text-slate-400 text-sm italic">No events.</p>
    <% } else { %>
      <ul class="space-y-3">
        <% events.forEach(function(event) { %>
          <li class="p-4 bg-white border border-slate-200 rounded-xl shadow-sm flex items-center justify-between gap-4">
            <div class="min-w-0">
              <a href="/events/<%= event.id %>" class="text-slate-900 font-semibold hover:text-blue-700 no-underline truncate block"><%= event.title %></a>
              <span class="text-slate-500 text-xs"><%= event.startTime.toLocaleDateString() %></span>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-slate-600 text-sm"><%= event.attendeeCount %> going</span>
              <span class="inline-block px-2.5 py-1 text-xs font-medium rounded-full <%= statusBadge(event.status) %>"><%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %></span>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </section>
<% } %>

<%- renderSection("Published", dashboard.published) %>
<%- renderSection("Draft", dashboard.draft) %>
<%- renderSection("Past & Cancelled", dashboard.pastOrCancelled) %>
