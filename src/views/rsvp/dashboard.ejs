<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">My RSVPs</h1>

  <!-- Upcoming section -->
  <section class="mb-10">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Upcoming</h2>

    <% if (dashboard.upcoming.length === 0) { %>
      <p class="text-gray-500 text-sm">You have no upcoming RSVPs.</p>
    <% } else { %>
      <div class="grid gap-4">
        <% dashboard.upcoming.forEach(function(entry) { %>
          <div class="bg-white rounded-lg shadow p-6 border border-gray-100">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-lg font-semibold text-gray-900"><%= entry.event.title %></h3>
                <p class="text-sm text-blue-600 mt-1 capitalize"><%= entry.event.category %></p>
              </div>
              <div class="text-right">
                <span class="text-sm text-gray-400"><%= entry.event.startTime.toLocaleDateString() %></span>
                <% if (entry.rsvp.status === "waitlisted") { %>
                  <p class="text-xs text-yellow-600 font-medium mt-1">Waitlisted</p>
                <% } else { %>
                  <p class="text-xs text-green-600 font-medium mt-1">Going</p>
                <% } %>
              </div>
            </div>
            <div class="mt-3 text-sm text-gray-500 flex gap-6">
              <span><%= entry.event.location %></span>
              <span><%= entry.event.startTime.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %></span>
            </div>
            <!-- Cancel RSVP — Sprint 2 will replace this with an HTMX partial -->
            <form method="POST" action="/events/<%= entry.event.id %>/rsvp" class="mt-4">
              <button
                type="submit"
                class="text-sm text-red-600 hover:text-red-800 underline"
              >Cancel RSVP</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <!-- Past & cancelled section -->
  <section>
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Past &amp; Cancelled</h2>

    <% if (dashboard.pastAndCancelled.length === 0) { %>
      <p class="text-gray-500 text-sm">Nothing here yet.</p>
    <% } else { %>
      <div class="grid gap-4">
        <% dashboard.pastAndCancelled.forEach(function(entry) { %>
          <div class="bg-white rounded-lg shadow p-6 border border-gray-100 opacity-75">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-lg font-semibold text-gray-700"><%= entry.event.title %></h3>
                <p class="text-sm text-gray-400 mt-1 capitalize"><%= entry.event.category %></p>
              </div>
              <div class="text-right">
                <span class="text-sm text-gray-400"><%= entry.event.startTime.toLocaleDateString() %></span>
                <p class="text-xs text-gray-400 mt-1 capitalize"><%= entry.rsvp.status %></p>
              </div>
            </div>
            <div class="mt-3 text-sm text-gray-400 flex gap-6">
              <span><%= entry.event.location %></span>
              <span><%= entry.event.startTime.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %></span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>
